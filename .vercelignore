# Ignore dependencies and package manager stores
node_modules
.pnpm-store
.pnpm-home
.pnpm-cache
.pnp
.pnp.js

# Ignore build artifacts
.next
out
build
dist
.turbo

# Ignore package-specific build artifacts and node_modules
apps/*/.next
apps/*/out
apps/*/build
apps/*/dist
apps/*/node_modules
packages/*/node_modules
packages/*/dist
packages/*/build

# Ignore git and CI/CD config
.git
.github
.husky

# Ignore Docker files
Dockerfile
docker-compose.yml
.dockerignore

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore miscellaneous
.DS_Store
*.pem
README.md
LICENSE
